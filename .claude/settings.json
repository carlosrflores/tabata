{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Edit",
      "Write",
      "WebFetch",

      "Bash(git status*)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(git show*)",
      "Bash(git branch*)",
      "Bash(git fetch*)",
      "Bash(git remote*)",
      "Bash(git stash list*)",

      "Bash(ls*)",
      "Bash(pwd)",
      "Bash(find*)",
      "Bash(wc*)",
      "Bash(file*)",
      "Bash(which*)",

      "Bash(node --version)",
      "Bash(npm --version)",
      "Bash(npm ls*)",
      "Bash(npm run lint*)",
      "Bash(npm run typecheck*)",
      "Bash(npm run build*)",
      "Bash(npm test*)",
      "Bash(npx tsc --noEmit*)",

      "mcp__github__get_file_contents",
      "mcp__github__list_branches",
      "mcp__github__list_commits",
      "mcp__github__get_commit",
      "mcp__github__list_pull_requests",
      "mcp__github__pull_request_read",
      "mcp__github__search_pull_requests",
      "mcp__github__list_issues",
      "mcp__github__issue_read",
      "mcp__github__search_issues",
      "mcp__github__search_code",
      "mcp__github__list_tags",
      "mcp__github__get_tag",
      "mcp__github__list_releases",
      "mcp__github__get_latest_release",
      "mcp__github__get_release_by_tag",
      "mcp__github__get_me"
    ],
    "deny": [
      "Bash(rm -rf*)",
      "Bash(rm -fr*)",
      "Bash(git push --force*)",
      "Bash(git push -f *)",
      "Bash(git push --force-with-lease*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -fd*)",
      "Bash(git clean -fdx*)",
      "Bash(git branch -D *)",
      "Bash(supabase db reset*)",
      "Bash(npx supabase db reset*)"
    ]
  },
  "sandbox": {
    "network": {
      "allowedDomains": [
        "*.supabase.co",
        "*.supabase.com",
        "api.vercel.com",
        "vercel.com",
        "*.vercel-storage.com",
        "api.onepeloton.com",
        "members.onepeloton.com"
      ]
    }
  }
}
