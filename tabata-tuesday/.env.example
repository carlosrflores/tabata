# ============================================================
# Tabata Tuesday — Environment Variables
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git
# ============================================================

# Supabase — from your Supabase project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Your deployed URL (used for internal API calls during build)
NEXT_PUBLIC_BASE_URL=https://your-app.vercel.app

# A random secret string — used to protect the /api/sync endpoint
# Generate one with: openssl rand -base64 32
CRON_SECRET=your-random-secret-here
